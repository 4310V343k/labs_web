NODE_ENV=production
PORT=5000

# PostgreSQL
DB_USER=app
DB_PASSWORD=change_me
DB_NAME=app_db
DB_HOST=db
DB_PORT=5432

# Domain - Caddy will serve <ACTUAL_DOMAIN> and obtain a *.<WILDCARD_DOMAIN> wildcard cert
WILDCARD_DOMAIN=example.com
ACTUAL_DOMAIN=app.example.com
ACME_EMAIL=you@example.com
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# CORS - must match the origin the browser sends.
FRONTEND_URL=https://app.example.com
